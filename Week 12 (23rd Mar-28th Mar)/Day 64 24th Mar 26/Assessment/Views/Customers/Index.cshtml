@model IEnumerable<Assessment.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Customers</h2>
        <a asp-action="Create" class="btn btn-success">+ Add Customer</a>
    </div>

    <!-- Card -->
    <div class="card shadow-sm">
        <div class="card-body p-0">

            <table class="table table-striped table-hover table-bordered align-middle mb-0">

                <thead class="table-dark text-center">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th style="width: 250px;">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @item.Name
                            </td>

                            <td>
                                <span class="text-muted">@item.Email</span>
                            </td>

                            <td>
                                @item.Address
                            </td>

                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.CustomerId"
                                   class="btn btn-sm btn-warning me-1">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.CustomerId"
                                   class="btn btn-sm btn-info me-1">
                                    View
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.CustomerId"
                                   class="btn btn-sm btn-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>

            </table>

        </div>
    </div>

</div>