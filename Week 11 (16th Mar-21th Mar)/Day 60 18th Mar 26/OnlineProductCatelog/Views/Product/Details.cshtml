
@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>
@model Product

<div class="row">
    <div class="col-md-6">
        <img src="@Model.ImageUrl" class="img-fluid rounded" />
    </div>

    <div class="col-md-6">
        <h2>@Model.Name</h2>
        <h4 class="text-success">$@Model.Price</h4>
        <p>@Model.Description</p>
        <a href="/Product" class="btn btn-secondary">Back</a>
    </div>
</div>

