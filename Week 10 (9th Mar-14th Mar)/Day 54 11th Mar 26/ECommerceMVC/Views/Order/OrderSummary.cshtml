@model ECommerceMVC.Models.Order

@{
    ViewData["Title"] = "OrderSummary";
}

<h2>Order Summary</h2>

<p>Customer: @Model.Customer.FullName</p>

<table class="table">
    <tr>
        <th>Product</th>
        <th>Quantity</th>
        <th>Price</th>
    </tr>

    @foreach (var item in Model.OrderDetails)
    {
        <tr>
            <td>@item.Product.Name</td>
            <td>@item.Quantity</td>
            <td>@item.UnitPrice</td>
        </tr>
    }
</table>